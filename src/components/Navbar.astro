---
interface Props {
    currentPage?: string;
}

const { currentPage = "home" } = Astro.props;

const navLinks = [
    { id: "home", label: "主页", href: "#home" },
    { id: "about", label: "关于我", href: "#about" },
    { id: "portfolio", label: "作品集", href: "#portfolio" },
    { id: "afterword", label: "写在最后", href: "#afterword" },
    { id: "contact", label: "联系我", href: "#contact" },
];
---

<nav class="navbar">
    <div class="navbar-container">
        <a href="#home" class="logo">
            <span class="logo-bracket">[</span>YC<span class="logo-bracket"
                >]</span
            >
        </a>
        <ul class="nav-links">
            {
                navLinks.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class:list={[
                                "nav-link",
                                { active: currentPage === link.id },
                            ]}
                            data-section={link.id}
                        >
                            <span class="nav-prefix">&gt;</span>
                            {link.label}
                            <span class="nav-cursor">_</span>
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</nav>

<script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
        const navLinks = document.querySelectorAll(".nav-link");
        const sections = document.querySelectorAll("section[id]");

        function updateActiveNav() {
            const scrollPos = window.scrollY + 100;

            sections.forEach(function (section) {
                const top = section.offsetTop;
                const height = section.offsetHeight;
                const id = section.getAttribute("id");

                if (scrollPos >= top && scrollPos < top + height) {
                    navLinks.forEach(function (link) {
                        link.classList.remove("active");
                        if (link.getAttribute("data-section") === id) {
                            link.classList.add("active");
                        }
                    });
                }
            });
        }

        window.addEventListener("scroll", updateActiveNav);
        updateActiveNav();
    });
</script>

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background-color: #faf6f0;
        border-bottom: 1px solid var(--color-border-dim);
    }

    .navbar-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--spacing-3xl);
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-primary);
        text-shadow: 0 0 10px var(--color-primary);
        transition: all var(--transition-fast);
        letter-spacing: 2px;
    }

    .logo-bracket {
        color: var(--color-secondary);
        opacity: 0.7;
    }

    .logo:hover {
        color: var(--color-accent);
        text-shadow: 0 0 20px var(--color-accent);
    }

    .nav-links {
        display: flex;
        gap: var(--spacing-xl);
    }

    .nav-link {
        font-family: var(--font-mono);
        font-size: 1rem;
        color: var(--color-text);
        padding: var(--spacing-sm) 0;
        position: relative;
        transition: all var(--transition-fast);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .nav-prefix {
        color: var(--color-primary);
        opacity: 0;
        transition: opacity var(--transition-fast);
    }

    .nav-cursor {
        color: var(--color-primary);
        opacity: 0;
        animation: blink 1s step-end infinite;
    }

    .nav-link:hover,
    .nav-link.active {
        color: var(--color-primary);
        text-shadow: 0 0 10px var(--color-primary);
    }

    .nav-link:hover .nav-prefix,
    .nav-link.active .nav-prefix {
        opacity: 1;
    }

    .nav-link:hover .nav-cursor,
    .nav-link.active .nav-cursor {
        opacity: 1;
    }

    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--color-primary);
        box-shadow: 0 0 10px var(--color-primary);
        transition: width var(--transition-normal);
    }

    .nav-link:hover::after,
    .nav-link.active::after {
        width: 100%;
    }

    /* Mobile Menu */
    @media (max-width: 768px) {
        .nav-links {
            gap: var(--spacing-md);
        }

        .nav-link {
            font-size: 0.9rem;
        }

        .nav-prefix,
        .nav-cursor {
            display: none;
        }
    }

    @media (max-width: 480px) {
        .navbar-container {
            padding: 0 var(--spacing-md);
        }

        .nav-links {
            gap: var(--spacing-sm);
        }

        .nav-link {
            font-size: 0.8rem;
        }
    }
</style>
