---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Tag from "../components/Tag.astro";
import { projects } from "../data/projects";
import { socialLinks } from "../data/socialLinks";
---

<Layout title="游戏作品集 | Jason 张奕晨">
	<Navbar currentPage="home" />

	<!-- ========== 主页 ========== -->
	<section id="home" class="hero">
		<div class="crt-monitor">
			<div class="monitor-frame">
				<div class="monitor-bezel">
					<div class="power-led"></div>
					<div class="brand-label">FAMILY COMPUTER</div>
				</div>
				<div class="screen-container">
					<div class="screen-inner">
						<video autoplay muted loop playsinline class="bg-video">
							<source
								src="https://videosofzyc.oss-cn-hongkong.aliyuncs.com/images/hero-video.webm"
								type="video/webm"
							/>
						</video>
						<div class="scanlines"></div>
					</div>
				</div>
				<div class="monitor-controls">
					<div class="control-knob"></div>
					<div class="control-knob"></div>
					<div class="control-slider"></div>
				</div>
			</div>
		</div>

		<div class="hero-content">
			<h1 class="name animate-fade-in-up">
				<span class="prefix">&gt;</span> Jason 张奕晨
				<span class="cursor">_</span>
			</h1>
		</div>

		<div
			class="scroll-indicator animate-fade-in"
			style="animation-delay: 0.6s"
		>
			<span>&gt; 向下滚动</span>
			<div class="arrow-down">▼</div>
		</div>
	</section>

	<!-- ========== 关于我 ========== -->
	<section id="about" class="about-section">
		<div class="container">
			<div class="terminal-window about-terminal">
				<div class="terminal-header">
					<span class="terminal-title">user_profile.exe</span>
				</div>
				<div class="terminal-body">
					<div class="about-content">
						<div class="portrait-section">
							<div class="portrait-wrapper">
								<img
									src="/images/个人照片.webp"
									alt="个人照片"
									class="portrait"
								/>
								<div class="portrait-scanline"></div>
							</div>
						</div>

						<div class="info-section">
							<div class="info-line">
								<span class="label">&gt; 用户名:</span>
								<span class="value"> 张奕晨</span>
							</div>
							<div class="info-line">
								<span class="label">&gt; 状态:</span>
								<span class="value status-online">在校</span>
							</div>
							<div class="info-line">
								<span class="label">&gt; 角色:</span>
								<span class="value">游戏设计/策划</span>
							</div>

							<div class="experience-section">
								<div class="info-line">
									<span class="label">&gt; 经历:</span>
								</div>
								<div class="experience-list">
									<div class="experience-item">
										<span class="exp-period">本科</span>
										<span class="exp-detail"
											>北京工业大学 (211) · 软件工程</span
										>
									</div>
									<div class="experience-item">
										<span class="exp-period">实习</span>
										<span class="exp-detail"
											>北京乐易互娱 · 休闲游戏关卡制作</span
										>
									</div>
									<div class="experience-item">
										<span class="exp-period"
											>大四（交换）</span
										>
										<span class="exp-detail"
											>爱尔兰都柏林大学 · 计算机科学
											(获学位)</span
										>
									</div>
									<div class="experience-item">
										<span class="exp-period"
											>硕士 (在读)</span
										>
										<span class="exp-detail"
											>英国华威大学 (QS69) · 游戏工程</span
										>
									</div>
								</div>
							</div>

							<div class="bio">
								<div class="info-line">
									<span class="label">&gt; BIO:</span>
								</div>
								<p class="bio-text">
									我是一个沉溺于'将创意工程化'的制作人。我既享受将喜欢的游戏分析并打磨成一份严谨的逻辑文档，更享受亲手用
									<strong class="skill-highlight"
										>C++/C#/Java/python</strong
									> 在极短时间内将其转化为高性能的游戏原型。
								</p>
								<p class="bio-text">
									具备 <strong class="skill-highlight"
										>Unity/Godot</strong
									> 深度开发经验及 <strong
										class="skill-highlight">Blender</strong
									> 建模基础，擅长 <strong
										class="skill-highlight">3C系统</strong
									> 与 <strong class="skill-highlight"
										>AI行为树</strong
									> 的搭建。我不仅追求交互瞬间的质感，更关注底层架构的可扩展性与逻辑闭环。作为技术出身的策划，我热衷于扮演团队中的'翻译官'，利用
									<strong class="skill-highlight"
										>AI/Python</strong
									> 脚本优化管线工具，解决设计与实现间的断层。我深知游戏是感性的艺术，但必须建立在理性且优雅的技术骨架之上。
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ========== 作品集 ========== -->
	<section id="portfolio" class="portfolio-section">
		<div class="container">
			<div class="game-console">
				<div class="console-screen">
					<div class="screen-bezel">
						<div
							class="slideshow-container"
							id="slideshow-container"
						>
							{
								projects[0].media.map((src, i) => (
									<img
										src={src}
										alt={`${projects[0].title} - ${i + 1}`}
										class:list={[
											"slide-image",
											{ active: i === 0 },
										]}
									/>
								))
							}
						</div>
						<button
							class="slide-arrow slide-arrow-left"
							id="slide-prev"
							aria-label="上一张">‹</button
						>
						<button
							class="slide-arrow slide-arrow-right"
							id="slide-next"
							aria-label="下一张">›</button
						>
						<div class="slide-indicators" id="slide-indicators">
							{
								projects[0].media.map((_, i) => (
									<span
										class:list={[
											"slide-indicator",
											{ active: i === 0 },
										]}
									/>
								))
							}
						</div>
						<div class="screen-overlay"></div>
					</div>
					<!-- 卡带插入窗口 -->
					<div
						class="cartridge-slot-window"
						id="cartridge-slot-window"
					>
						<div
							class="inserted-cartridge-holder"
							id="inserted-holder"
						>
						</div>
						<div class="slot-window-glass"></div>
					</div>
				</div>

				<div class="project-info">
					<h3 id="project-title" class="project-title">
						<span class="prefix">&gt;</span>
						{projects[0].title}
					</h3>
					<div id="project-tags" class="project-tags">
						{
							projects[0].tags.map((tag) => (
								<Tag text={tag.text} color={tag.color} />
							))
						}
					</div>
					<p id="project-duration" class="project-duration">
						<span class="prefix">&gt;</span> 制作时长：{
							projects[0].duration
						}周
					</p>
					<p
						id="project-description"
						class="project-desc"
						set:html={projects[0].description}
					/>
				</div>
			</div>

			<div class="cartridge-slot">
				<div class="slot-label">点击下方卡带切换</div>
				<div class="project-selector">
					{
						projects.map((project, index) => (
							<div
								class:list={[
									"cartridge",
									{ active: index === 0 },
								]}
								data-index={index}
								data-title={project.title}
								data-description={project.description}
								data-media={JSON.stringify(project.media)}
								data-tags={JSON.stringify(project.tags)}
								data-duration={project.duration}
								aria-label={`查看 ${project.title}`}
								role="button"
								tabindex="0"
							>
								<div class="cartridge-top">
									<div class="cartridge-grip-left" />
									<div class="cartridge-grip-right" />
								</div>
								<div class="cartridge-label">
									<img
										src={project.cover}
										alt={project.title}
										class="cartridge-cover"
									/>
									<span class="cartridge-number">
										{String(index + 1).padStart(2, "0")}
									</span>
								</div>
								<div class="cartridge-bottom">
									<div class="cartridge-pins" />
								</div>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ========== 写在最后 ========== -->
	<section id="afterword" class="afterword-section">
		<div class="container">
			<div class="terminal-window afterword-terminal">
				<div class="terminal-header">
					<span class="terminal-title">afterword.exe</span>
				</div>
				<div class="terminal-body">
					<div class="afterword-content">
						<h2>
							<span class="prefix">&gt;</span> 写在最后
							<span class="cursor">_</span>
						</h2>
						<p class="afterword-subtitle">// 关于我的游戏世界观</p>

						<div class="afterword-intro">
							<p class="afterword-text">
								感谢你耐心翻阅我的作品。如果你能看到这里，说明你是和我一样做事认真的人。现在请允许我说点心里话：作为一名行走在<span
									class="highlight">技术</span
								>与<span class="highlight">艺术</span
								>交界处的开发者，我始终信奉两个信条：<span
									class="highlight-strong">实用主义</span
								>与<span class="highlight-strong">审美至上</span
								>。
							</p>
						</div>

						<div class="afterword-block">
							<h3>
								<span class="prefix">&gt;</span> 实用主义：技术是通往想象力的桥梁
							</h3>
							<p class="afterword-text">
								自 2021 年进入<span class="highlight"
									>北京工业大学</span
								>以来，开发"好玩的游戏"始终是我学习技术的终极动力。对我而言，<span
									class="highlight-strong"
									>技术是手段而非目的</span
								>。我并非那种闭门钻研底层算法的纯粹极客，我更像是一个<span
									class="highlight">"工匠"</span
								>：我学习计算机、钻研好用的AI，是为了补齐制作中最短的那块板，让创意不因技术门槛而流产。
							</p>
							<p class="afterword-text">
								在<span class="highlight">爱尔兰都柏林大学</span
								>交换期间，我选择"<span class="highlight"
									>让大语言模型扮演游戏玩家</span
								>"作为毕设方向并获得 <span
									class="highlight-strong">A 等成绩</span
								>。导师因此邀请我留校深造，但我拒绝了。比起实验室里的学术模型，我更痴迷于如何将<span
									class="highlight">大语言模型（LLM）</span
								>低成本、高效率地引入实际开发。我可以不是算法的创造者，但我一定是它<span
									class="highlight-strong"
									>最敏锐的应用者</span
								>。目前在<span class="highlight">华威大学</span
								>，我正继续探索"<span class="highlight"
									>让AI辅助全流程游戏开发</span
								>"，致力于让生产力实现质的飞跃。
							</p>
						</div>

						<div class="afterword-block">
							<h3>
								<span class="prefix">&gt;</span> 审美至上：第九艺术的灵魂锚点
							</h3>
							<p class="afterword-text">
								我深信，<span class="highlight-strong"
									>审美能力是游戏设计师的护城河</span
								>。无论技术如何更迭，视觉、听觉乃至交互中传达的"美"，是游戏作为<span
									class="highlight">第九艺术</span
								>能被玩家铭记的本质。
							</p>
							<p class="afterword-text">
								我非常现实地看待这一点：<span
									class="highlight-strong"
									>人类是视觉动物</span
								>。无论受众是追求极致体验的硬核玩家，还是在碎片化时间寻求慰藉的普通大众，优秀的视觉表现永远是<span
									class="highlight-strong">第一生产力</span
								>——只有先具备"让用户点进来"的审美吸引力，我们苦心经营的玩法逻辑才有机会展现在世人面前。
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ========== 联系我 ========== -->
	<section id="contact" class="contact-section">
		<div class="container">
			<div class="terminal-window contact-terminal">
				<div class="terminal-header">
					<span class="terminal-title"
