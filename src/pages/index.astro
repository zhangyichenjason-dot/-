</Layout>

<!-- 作品切换脚本 -->
<script is:inline>
	document.addEventListener("DOMContentLoaded", function () {
		const cartridges = document.querySelectorAll(".cartridge");
		const slideshowContainer = document.getElementById(
			"slideshow-container",
		);
		const indicatorsContainer = document.getElementById("slide-indicators");
		const prevBtn = document.getElementById("slide-prev");
		const nextBtn = document.getElementById("slide-next");
		const titleEl = document.getElementById("project-title");
		const descEl = document.getElementById("project-description");
		const durationEl = document.getElementById("project-duration");
		const tagsEl = document.getElementById("project-tags");
		const slotWindow = document.getElementById("cartridge-slot-window");
		const insertedHolder = document.getElementById("inserted-holder");

		const tagColorMap = {
			blue: "var(--tag-cyan)",
			purple: "var(--tag-purple)",
			pink: "var(--tag-pink)",
			green: "var(--tag-green)",
			orange: "var(--tag-amber)",
			amber: "var(--tag-amber)",
			red: "var(--tag-red)",
			cyan: "var(--tag-cyan)",
		};

		let currentInserted = null;
		let isAnimating = false;

		// ========== 轮播逻辑 ==========
		var slideElements = [];
		var slideIndicators = [];
		var currentSlideIndex = 0;
		var autoPlayTimer = null;
		var isFirstSlide = true;

		function isVideo(src) {
			return /\.(mp4|webm|ogg)$/i.test(src);
		}

		function stopAllVideos() {
			slideElements.forEach(function (el) {
				if (el.tagName === "VIDEO") {
					el.pause();
					el.currentTime = 0;
					el.removeAttribute("data-ended-listener");
				}
			});
		}

		function scheduleNext() {
			if (autoPlayTimer) {
				clearTimeout(autoPlayTimer);
				autoPlayTimer = null;
			}
			var current = slideElements[currentSlideIndex];
			if (current && current.tagName === "VIDEO") {
				// 视频：等播放完毕再切换
				var onEnded = function () {
					current.removeEventListener("ended", onEnded);
					goToSlide(currentSlideIndex + 1);
					scheduleNext();
				};
				current.addEventListener("ended", onEnded);
			} else {
				// 图片：用定时器
				var delay = isFirstSlide ? 800 : 3000;
				autoPlayTimer = setTimeout(function () {
					goToSlide(currentSlideIndex + 1);
					isFirstSlide = false;
					scheduleNext();
				}, delay);
			}
		}

		function goToSlide(index) {
			if (slideElements.length === 0) return;
			if (index < 0) index = slideElements.length - 1;
			if (index >= slideElements.length) index = 0;

			// 暂停当前视频
			var oldEl = slideElements[currentSlideIndex];
			if (oldEl && oldEl.tagName === "VIDEO") {
				oldEl.pause();
				oldEl.currentTime = 0;
			}

			// 隐藏所有
			slideElements.forEach(function (el) {
				el.classList.remove("active");
				el.style.opacity = "0";
			});
			slideIndicators.forEach(function (dot) {
				dot.classList.remove("active");
				dot.style.background = "rgba(255,255,255,0.4)";
				dot.style.transform = "scale(1)";
			});

			// 显示新的
			currentSlideIndex = index;
			var newEl = slideElements[currentSlideIndex];
			newEl.classList.add("active");
			newEl.style.opacity = "1";

			// 如果是视频，从头播放
			if (newEl.tagName === "VIDEO") {
				newEl.currentTime = 0;
				newEl.play();
			}

			if (slideIndicators[currentSlideIndex]) {
				slideIndicators[currentSlideIndex].classList.add("active");
				slideIndicators[currentSlideIndex].style.background =
					"rgba(255,255,255,0.9)";
				slideIndicators[currentSlideIndex].style.transform =
					"scale(1.2)";
			}
		}

		function nextSlide() {
			isFirstSlide = false;
			goToSlide(currentSlideIndex + 1);
			resetAutoPlay();
		}

		function prevSlide() {
			isFirstSlide = false;
			goToSlide(currentSlideIndex - 1);
			resetAutoPlay();
		}

		function resetAutoPlay() {
			if (autoPlayTimer) {
				clearTimeout(autoPlayTimer);
				autoPlayTimer = null;
			}
			scheduleNext();
		}

		function applyMediaStyles(el) {
			el.style.position = "absolute";
			el.style.top = "0";
			el.style.left = "0";
			el.style.width = "100%";
			el.style.height = "100%";
			el.style.objectFit = "cover";
			el.style.objectPosition = "top";
			el.style.transition = "opacity 0.5s ease";
		}

		function startSlideshow(mediaSources, title) {
			// 停止之前的
			if (autoPlayTimer) {
				clearTimeout(autoPlayTimer);
				autoPlayTimer = null;
			}
			stopAllVideos();

			// 重建
			slideshowContainer.innerHTML = "";
			indicatorsContainer.innerHTML = "";
			slideElements = [];
			slideIndicators = [];
			currentSlideIndex = 0;
			isFirstSlide = true;

			mediaSources.forEach(function (src, i) {
				var el;
				if (isVideo(src)) {
					el = document.createElement("video");
					el.src = src;
					el.muted = true;
					el.playsInline = true;
					el.preload = "auto";
					el.className = "slide-media";
				} else {
					el = document.createElement("img");
					el.src = src;
					el.alt = title + " - " + (i + 1);
					el.className = "slide-image";
				}
				applyMediaStyles(el);
				el.style.opacity = i === 0 ? "1" : "0";
				if (i === 0) el.classList.add("active");
				slideshowContainer.appendChild(el);
				slideElements.push(el);

				var dot = document.createElement("span");
				dot.className = "slide-indicator";
				dot.style.width = "8px";
				dot.style.height = "8px";
				dot.style.borderRadius = "50%";
				dot.style.cursor = "pointer";
				dot.style.transition =
					"background 0.3s ease, transform 0.3s ease";
				dot.style.background =
					i === 0 ? "rgba(255,255,255,0.9)" : "rgba(255,255,255,0.4)";
				dot.style.transform = i === 0 ? "scale(1.2)" : "scale(1)";
				if (i === 0) dot.classList.add("active");
				dot.addEventListener("click", function () {
					isFirstSlide = false;
					goToSlide(i);
					resetAutoPlay();
				});
				indicatorsContainer.appendChild(dot);
				slideIndicators.push(dot);
			});

			// 如果第一个是视频，立即播放
			if (
				slideElements.length > 0 &&
				slideElements[0].tagName === "VIDEO"
			) {
				slideElements[0].play();
			}

			// 启动自动推进
			if (mediaSources.length > 1) {
				scheduleNext();
			}
		}

		// 箭头点击
		prevBtn.addEventListener("click", function (e) {
			e.stopPropagation();
			prevSlide();
		});
		nextBtn.addEventListener("click", function (e) {
			e.stopPropagation();
			nextSlide();
		});

		// 初始化轮播（页面初始已有 Astro 渲染的图片）
		function initSlideshow() {
			slideElements = Array.from(
				slideshowContainer.querySelectorAll(
					".slide-image, .slide-media",
				),
			);
			slideIndicators = Array.from(
				indicatorsContainer.querySelectorAll(".slide-indicator"),
			);
			currentSlideIndex = 0;
			isFirstSlide = true;

			// 给指示器加点击事件
			slideIndicators.forEach(function (dot, i) {
				dot.addEventListener("click", function () {
					isFirstSlide = false;
					goToSlide(i);
					resetAutoPlay();
				});
			});

			// 启动自动推进
			if (slideElements.length > 1) {
				scheduleNext();
			}
		}

		// ========== 卡带逻辑 ==========

		// 计算两个目标位置
		function getFlightPositions(cartridge) {
			var cartridgeRect = cartridge.getBoundingClientRect();
			var slotRect = slotWindow.getBoundingClientRect();

			// X：与槽窗水平居中对齐
			var targetX =
				slotRect.left + slotRect.width / 2 - cartridgeRect.width / 2;

			// Phase1 Y：槽窗正下方
			var belowY = slotRect.bottom;

			// Phase2 Y：槽窗中心
			var insideY =
				slotRect.top + slotRect.height / 2 - cartridgeRect.height / 2;

			return {
				flyX: targetX - cartridgeRect.left,
				belowY: belowY - cartridgeRect.top,
				insideY: insideY - cartridgeRect.top,
			};
		}

		function createInsertedClone(cartridge) {
			insertedHolder.innerHTML = "";
			var clone = cartridge.cloneNode(true);
			clone.classList.remove(
				"active",
				"flying-to-slot",
				"sliding-into-slot",
				"inserted",
			);
			clone.removeAttribute("data-index");
			insertedHolder.appendChild(clone);
		}

		function removeInsertedClone() {
			insertedHolder.innerHTML = "";
		}

		function updateProjectInfo(cartridge) {
			var title = cartridge.getAttribute("data-title") || "";
			var description = cartridge.getAttribute("data-description") || "";
			var mediaData = cartridge.getAttribute("data-media") || "[]";
			var tagsData = cartridge.getAttribute("data-tags") || "[]";
			var duration = cartridge.getAttribute("data-duration") || "";

			// 启动新的轮播
			var images = JSON.parse(mediaData);
			startSlideshow(images, title);

			if (titleEl) {
				titleEl.innerHTML = '<span class="prefix">&gt;</span> ' + title;
			}

			if (durationEl && duration) {
				durationEl.innerHTML =
					'<span class="prefix">&gt;</span> 制作时长：' +
					duration +
					"周";
			}

			if (descEl) {
				descEl.innerHTML = description;
			}

			if (tagsEl) {
				var tags = JSON.parse(tagsData);
				tagsEl.innerHTML = tags
					.map(function (tag) {
						var color = tagColorMap[tag.color] || tagColorMap.cyan;
						return (
							'<span class="tag" style="' +
							"--tag-color: " +
							color +
							"; " +
							"display: inline-flex; align-items: center; " +
							"padding: 4px 8px; background: transparent; " +
							"color: " +
							color +
							"; " +
							"border: 1px solid " +
							color +
							"; " +
							"font-family: var(--font-mono); font-size: 0.85rem; " +
							"letter-spacing: 1px; text-transform: uppercase; " +
							"transition: all var(--transition-fast);" +
							'">' +
							'<span style="margin-right:2px;opacity:0.6">[</span>' +
							tag.text +
							'<span style="margin-left:2px;opacity:0.6">]</span>' +
							"</span>"
						);
					})
					.join("");
			}
		}

		// 两段式插入：Phase1 飞到下方 → Phase2 直线上滑
		function flyToSlot(cartridge, callback) {
			var pos = getFlightPositions(cartridge);

			// Phase 1：飞到槽窗正下方
			cartridge.classList.add("flying-to-slot");
			// 用 requestAnimationFrame 确保 transition 类已应用
			requestAnimationFrame(function () {
				cartridge.style.transform =
					"translate(" + pos.flyX + "px, " + pos.belowY + "px)";
			});

			setTimeout(function () {
				// Phase 2：直线向上插入槽窗
				cartridge.classList.remove("flying-to-slot");
				cartridge.classList.add("sliding-into-slot");
				requestAnimationFrame(function () {
					cartridge.style.transform =
						"translate(" + pos.flyX + "px, " + pos.insideY + "px)";
					cartridge.style.opacity = "0";
				});

				setTimeout(function () {
					// 完成：隐藏原卡带（保留inline样式不清理，防止闪回）
					cartridge.classList.add("inserted");
					cartridge.classList.remove("sliding-into-slot");
					createInsertedClone(cartridge);
					if (callback) callback();
				}, 300);
			}, 400);
		}

		// 飞回原位
		function flyBack(cartridge, callback) {
			if (!cartridge) {
				if (callback) callback();
				return;
			}

			removeInsertedClone();

			// 此时卡带仍保留插入时的 transform 和 opacity:0
			cartridge.classList.remove("inserted");
			cartridge.classList.add("flying-back");
			// RAF 中重置样式，transition 会平滑过渡回原位
			requestAnimationFrame(function () {
				cartridge.style.transform = "";
				cartridge.style.opacity = "1";
			});

			setTimeout(function () {
				cartridge.classList.remove("flying-back");
				cartridge.classList.remove("active");
				cartridge.style.transform = "";
				cartridge.style.opacity = "";
				if (callback) callback();
			}, 400);
		}

		function initFirstCartridge() {
			var firstCartridge = cartridges[0];
			if (firstCartridge) {
				firstCartridge.classList.add("active");
				updateProjectInfo(firstCartridge);
				setTimeout(function () {
					flyToSlot(firstCartridge, function () {
						currentInserted = firstCartridge;
					});
				}, 300);
			}
		}

		cartridges.forEach(function (cartridge) {
			cartridge.addEventListener("click", function () {
				if (isAnimating || cartridge === currentInserted) return;
				isAnimating = true;

				if (currentInserted) {
					flyBack(currentInserted, function () {
						cartridge.classList.add("active");
						flyToSlot(cartridge, function () {
							currentInserted = cartridge;
							isAnimating = false;
						});
						updateProjectInfo(cartridge);
					});
				} else {
					cartridge.classList.add("active");
					flyToSlot(cartridge, function () {
						currentInserted = cartridge;
						isAnimating = false;
					});
					updateProjectInfo(cartridge);
				}
			});
		});

		initFirstCartridge();
	});
</script>

