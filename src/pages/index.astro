					>
				</div>
				<div class="terminal-body">
					<div class="contact-content">
						<h2>
							<span class="prefix">&gt;</span> 联系我
							<span class="cursor">_</span>
						</h2>
						<p class="subtitle">
							//
							如果你对我的作品感兴趣，或者想要合作，欢迎随时联系我！
						</p>

						<div class="social-links">
							{
								socialLinks.map((link) => (
									<a
										href={link.href}
